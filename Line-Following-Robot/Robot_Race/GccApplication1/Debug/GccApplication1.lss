float CurrentErrorCalc(void)
{
    if (!centreSensor) // Line is directly under the center sensor (L:1, C:0, R:1)
 22c:	8f b1       	in	r24, 0x0f	; 15
        {
            // Ideal: Line is perfectly centered.
            return 0.0;
        }
        else if (!leftSensor) // Line is partially or fully under the left sensor (0, 1, 1 or 0, 0, 1)
 22e:	8f b1       	in	r24, 0x0f	; 15
        {
            // We are severely off to the left, need a strong correction to the RIGHT (negative error).
            ledLeftOn;
            return -3.0;
        }
        else if (!rightSensor) // Line is partially or fully under the right sensor (1, 1, 0 or 1, 0, 0)
 230:	8f b1       	in	r24, 0x0f	; 15
        {
            // We are severely off to the right, need a strong correction to the LEFT (positive error).
